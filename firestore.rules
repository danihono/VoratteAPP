rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(myUid())).data;
    }

    function isAdmin() {
      return isSignedIn() && myProfile().role == 'admin';
    }

    function isGestor() {
      return isSignedIn() && myProfile().role == 'gestor';
    }

    // Verifica se o aluno (userId) pertence ao time do gestor autenticado
    function isMyTeamMember(userId) {
      return isGestor() &&
        get(/databases/$(database)/documents/users/$(userId)).data.gestorId == myUid();
    }

    // ─── /users/{uid} ───────────────────────────────────────────────────────
    match /users/{uid} {
      // Leitura: próprio doc, gestor do time, ou admin
      allow read: if isSignedIn() && (
        myUid() == uid ||
        isMyTeamMember(uid) ||
        isAdmin()
      );

      // Escrita: admin pode tudo; o próprio user pode editar APENAS campos seguros.
      // Bloqueia escalada de privilégio (role) e mudanças que afetam isolamento
      // por empresa/time (companyId, gestorId, invited, email, companyName, etc).
      // affectedKeys() = chaves que mudaram entre resource e request.resource.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (myUid() == uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['name', 'jobTitle', 'discCompleted', 'discMain', 'lastSeen']))
      );
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /companies/{companyId} ─────────────────────────────────────────────
    match /companies/{companyId} {
      // Qualquer usuário autenticado da empresa pode ler
      allow read: if isSignedIn() && (
        myProfile().companyId == companyId ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    // ─── /disc_results/{uid} ────────────────────────────────────────────────
    match /disc_results/{uid} {
      // Leitura: próprio resultado, gestor do aluno, ou admin
      allow read: if isSignedIn() && (
        myUid() == uid ||
        isMyTeamMember(uid) ||
        isAdmin()
      );

      // Escrita: apenas o próprio aluno salva seu resultado (via fbSaveDiscResult)
      allow write: if isSignedIn() && myUid() == uid;
    }

    // ─── /reports/{reportId} ────────────────────────────────────────────────
    match /reports/{reportId} {
      // Leitura: dono do relatório, gestor do dono, ou admin
      allow read: if isSignedIn() && (
        resource.data.userId == myUid() ||
        isMyTeamMember(resource.data.userId) ||
        isAdmin()
      );

      // Criação: admin pode tudo (wizard grava sem userId fixo); dono comum
      // precisa indicar o próprio uid em userId.
      allow create: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.userId == myUid()
      );

      // Atualização: dono do relatório (necessário para reexportar self_{uid}
      // sobrescrevendo o mesmo doc) ou admin. Sem este allow, reexportações
      // do aluno eram silenciosamente bloqueadas pela rule anterior.
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == myUid()
      );

      allow delete: if isAdmin();
    }
  }
}
